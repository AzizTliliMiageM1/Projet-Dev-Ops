# External API configuration template
# Copy this file to .env and fill real values.

# Mailgun
MAILGUN_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.your-domain.com
MAILGUN_FROM=noreply@your-domain.com

# Okta
OKTA_ORG_URL=https://dev-xxxxxxxx.okta.com
OKTA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe
# Use sk_test_... in development, sk_live_... in production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Optional
# PORT=4567
# DISABLE_AUTH_FOR_TESTS=false
